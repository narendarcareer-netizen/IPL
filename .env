# ===============================
# APP
# ===============================
APP_ENV=local
APP_NAME=ipl-predictor

# ===============================
# DATABASE
# ===============================
POSTGRES_DB=ipl_db
POSTGRES_USER=ipl_user
POSTGRES_PASSWORD=ipl_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql://ipl_user:ipl_password@postgres:5432/ipl_db

# ===============================
# REDIS
# ===============================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ===============================
# FASTAPI
# ===============================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ===============================
# FRONTEND
# ===============================
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
INTERNAL_BACKEND_URL=http://backend:8000

# ===============================
# ML SETTINGS
# ===============================
MODEL_DIR=/app/models
DATA_DIR=/app/data
FEATURE_STORE_DIR=/app/features

# ===============================
# MLFLOW
# ===============================
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=ipl_prediction

# ===============================
# CRICKET DATA API
# ===============================
CRICKET_API_KEY=
CRICKET_API_URL=https://api.cricapi.com

# ===============================
# ODDS API
# ===============================
ODDS_API_KEY=b8825d843a8fb346761eb4f3cbdc8414
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
ODDS_SPORT_KEY=cricket_ipl

# ===============================
# SCHEDULER
# ===============================
PREDICTION_REFRESH_MINUTES=15
ODDS_REFRESH_MINUTES=5
LINEUP_REFRESH_MINUTES=10

# ===============================
# TRAINING
# ===============================
TRAIN_START_YEAR=2008
TRAIN_END_YEAR=2024

# ===============================
# FEATURE FLAGS
# ===============================
ENABLE_SHAP=true
ENABLE_CALIBRATION=true
ENABLE_ODDS_MODEL=true
