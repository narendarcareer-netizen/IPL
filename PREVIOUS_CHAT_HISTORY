def extract_player_stats(data, team1_id, team2_id, conn):
    innings = data.get("innings", [])
    stats = {}

    for inn in innings:
        team_name = inn.get("team")
        team_id = team1_id if team_name else team2_id

        for over in inn.get("overs", []):
            for d in over.get("deliveries", []):
                batter = d.get("batter")
                bowler = d.get("bowler")

                runs = d.get("runs", {}).get("batter", 0)
                total_runs = d.get("runs", {}).get("total", 0)

                # Batter stats
                if batter:
                    pid = upsert_player(conn, batter)
                    key = (pid, team_id)

                    stats.setdefault(key, {
                        "runs": 0,
                        "balls": 0,
                        "fours": 0,
                        "sixes": 0,
                        "dismissed": False,
                        "wickets": 0,
                        "balls_bowled": 0,
                        "runs_conceded": 0,
                    })

                    stats[key]["runs"] += runs
                    stats[key]["balls"] += 1

                    if runs == 4:
                        stats[key]["fours"] += 1
                    elif runs == 6:
                        stats[key]["sixes"] += 1

                # Bowler stats
                if bowler:
                    pid = upsert_player(conn, bowler)
                    key = (pid, team_id)

                    stats.setdefault(key, {
                        "runs": 0,
                        "balls": 0,
                        "fours": 0,
                        "sixes": 0,
                        "dismissed": False,
                        "wickets": 0,
                        "balls_bowled": 0,
                        "runs_conceded": 0,
                    })

                    stats[key]["balls_bowled"] += 1
                    stats[key]["runs_conceded"] += total_runs

                # Wickets
                for w in d.get("wickets", []):
                    player_out = w.get("player_out")
                    if player_out:
                        pid = upsert_player(conn, player_out)
                        key = (pid, team_id)
                        stats.setdefault(key, {})
                        stats[key]["dismissed"] = True

                    if bowler:
                        pid = upsert_player(conn, bowler)
                        key = (pid, team_id)
                        stats.setdefault(key, {})
                        stats[key]["wickets"] += 1

    return stats
