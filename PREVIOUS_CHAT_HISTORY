from sqlalchemy import text
from sqlalchemy.orm import Session


def elo_prob(r1: float, r2: float) -> float:
    return 1.0 / (1.0 + 10 ** ((r2 - r1) / 400.0))


def predict_match(db: Session, match_id: int, stage: str, cutoff_time_utc, model_uri: str | None = None) -> dict:
    match = db.execute(
        text("""
            SELECT
                m.match_id,
                m.team1_id,
                m.team2_id,
                t1.name AS team1_name,
                t2.name AS team2_name
            FROM matches m
            JOIN teams t1 ON m.team1_id = t1.team_id
            JOIN teams t2 ON m.team2_id = t2.team_id
            WHERE m.match_id = :match_id
        """),
        {"match_id": match_id},
    ).mappings().first()

    if not match:
        raise ValueError(f"Match {match_id} not found")

    team1_rating_row = db.execute(
        text("SELECT rating FROM team_elo_ratings WHERE team_id = :team_id"),
        {"team_id": match["team1_id"]},
    ).first()

    team2_rating_row = db.execute(
        text("SELECT rating FROM team_elo_ratings WHERE team_id = :team_id"),
        {"team_id": match["team2_id"]},
    ).first()

    r1 = float(team1_rating_row[0]) if team1_rating_row else 1500.0
    r2 = float(team2_rating_row[0]) if team2_rating_row else 1500.0

    p1 = elo_prob(r1, r2)
    p2 = 1.0 - p1

    confidence = abs(p1 - 0.5) * 2.0

    return {
        "match_id": match["match_id"],
        "stage": stage,
        "model_name": "elo_baseline",
        "team1_name": match["team1_name"],
        "team2_name": match["team2_name"],
        "team1_rating": r1,
        "team2_rating": r2,
        "team1_win_prob": p1,
        "team2_win_prob": p2,
        "confidence_score": confidence,
        "cutoff_time_utc": cutoff_time_utc.isoformat(),
    }
