import os
import pandas as pd
from sqlalchemy import create_engine, text

DATABASE_URL = os.environ["DATABASE_URL"]

def elo_prob(r1: float, r2: float) -> float:
    return 1.0 / (1.0 + 10 ** ((r2 - r1) / 400.0))

def main():
    engine = create_engine(DATABASE_URL, pool_pre_ping=True)

    q = text("""
        SELECT
            m.match_id,
            m.start_time_utc,
            m.team1_id,
            m.team2_id,
            m.winner_team_id,
            t1.name AS team1_name,
            t2.name AS team2_name,
            COALESCE(e1.rating, 1500) AS team1_elo,
            COALESCE(e2.rating, 1500) AS team2_elo
        FROM matches m
        JOIN teams t1 ON m.team1_id = t1.team_id
        JOIN teams t2 ON m.team2_id = t2.team_id
        LEFT JOIN team_elo_ratings e1 ON m.team1_id = e1.team_id
        LEFT JOIN team_elo_ratings e2 ON m.team2_id = e2.team_id
        WHERE m.competition = 'Indian Premier League'
          AND m.completed = true
          AND m.winner_team_id IS NOT NULL
        ORDER BY m.start_time_utc ASC, m.match_id ASC
    """)

    df = pd.read_sql(q, engine)

    if df.empty:
        print("No completed IPL matches found.")
        return

    df["elo_diff"] = df["team1_elo"] - df["team2_elo"]
    df["bookmaker_implied_prob"] = 0.5
    df["line_movement"] = 0.0
    df["team1_win_prob_elo"] = df.apply(lambda r: elo_prob(r["team1_elo"], r["team2_elo"]), axis=1)
    df["team1_won"] = (df["winner_team_id"] == df["team1_id"]).astype(int)

    out_path = "/app/ml/artifacts/pre_match_features.csv"
    os.makedirs("/app/ml/artifacts", exist_ok=True)
    df.to_csv(out_path, index=False)

    print(f"Saved features to {out_path}")
    print(df.head(10).to_string(index=False))

if __name__ == "__main__":
    main()
