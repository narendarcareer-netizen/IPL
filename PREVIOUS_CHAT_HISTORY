                        stats[out_key]["dismissed"] = True

                    if bowler:
                        bowler_id = upsert_player(conn, bowler)
                        bowler_key = (bowler_id, bowling_team_id)
                        ensure_stat(bowler_key)
                        stats[bowler_key]["wickets"] += 1

    return stats
