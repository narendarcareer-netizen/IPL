        FROM latest_team_players ltp
        LEFT JOIN latest_player_form lpf
          ON ltp.player_id = lpf.player_id
        LEFT JOIN team_elo_ratings ter
          ON ltp.team_id = ter.team_id
        ORDER BY ltp.team_id, ltp.player_id
