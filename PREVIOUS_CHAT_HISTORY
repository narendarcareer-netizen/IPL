import os
import pandas as pd
from sqlalchemy import create_engine, text

DATABASE_URL = os.environ["DATABASE_URL"]


def main():
    engine = create_engine(DATABASE_URL, pool_pre_ping=True)

    # ✅ THIS IS WHERE SQL GOES
    q = text("""
        SELECT
            pms.team_id,
            p.player_id,
            p.full_name,
            MAX(pfs.as_of_time_utc) AS as_of_time_utc,
            MAX(pfs.batting_form_score) AS batting_form_score,
            MAX(pfs.bowling_form_score) AS bowling_form_score,
            MAX(pfs.batting_runs_avg) AS batting_runs_avg,
            MAX(pfs.bowling_wkts_avg) AS bowling_wkts_avg
        FROM player_match_stats pms
        JOIN players p
          ON pms.player_id = p.player_id
        JOIN player_form_snapshots pfs
          ON pms.player_id = pfs.player_id
        GROUP BY pms.team_id, p.player_id, p.full_name
    """)

    df = pd.read_sql(q, engine)

    if df.empty:
        print("No player data found")
        return

    # ✅ Create player ranking score
    df["combined_score"] = (
        0.45 * df["batting_form_score"].fillna(0)
        + 0.35 * df["bowling_form_score"].fillna(0)
        + 0.10 * df["batting_runs_avg"].fillna(0)
        + 0.10 * df["bowling_wkts_avg"].fillna(0)
    )

    rows = []

    # ✅ Pick top 11 players per team
    for team_id, g in df.groupby("team_id"):
        xi = g.sort_values("combined_score", ascending=False).head(11)

        for rank, (_, r) in enumerate(xi.iterrows(), start=1):
            rows.append({
                "team_id": int(team_id),
                "player_id": int(r["player_id"]),
                "rank": rank
            })

    xi_df = pd.DataFrame(rows)

    # ✅ Save into DB
    with engine.begin() as conn:
        conn.execute(text("DELETE FROM probable_xi"))

        for _, row in xi_df.iterrows():
            conn.execute(
                text("""
                    INSERT INTO probable_xi (
                        team_id,
                        player_id,
                        rank
                    )
                    VALUES (
                        :team_id,
                        :player_id,
                        :rank
                    )
                """),
                row.to_dict(),
            )

    print(f"Inserted probable XI rows: {len(xi_df)}")
    print(xi_df.head(20))


if __name__ == "__main__":
    main()
