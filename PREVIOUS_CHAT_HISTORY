    df["elo_diff"] = df["team1_elo"] - df["team2_elo"]
    df["batting_strength_diff"] = df["team1_batting_strength"] - df["team2_batting_strength"]
    df["bowling_strength_diff"] = df["team1_bowling_strength"] - df["team2_bowling_strength"]
