import os
import joblib
import pandas as pd
import shap
from sqlalchemy import create_engine, text

DATABASE_URL = os.environ["DATABASE_URL"]
MODEL_PATH = "/app/ml/artifacts/logreg_prematch.joblib"
FEATURES_PATH = "/app/ml/artifacts/upcoming_match_features.csv"


def main():
    engine = create_engine(DATABASE_URL, pool_pre_ping=True)

    bundle = joblib.load(MODEL_PATH)
    model = bundle["model"]
    feature_cols = bundle["feature_cols"]

    df = pd.read_csv(FEATURES_PATH)

    if df.empty:
        print("No features found.")
        return

    X = df[feature_cols].fillna(0.0)

    explainer = shap.Explainer(model, X)
    shap_values = explainer(X)

    rows = []

    for i in range(len(df)):
        match_id = int(df.iloc[i]["match_id"])

        values = shap_values.values[i]
        feature_names = feature_cols

        pairs = list(zip(feature_names, values))
        pairs.sort(key=lambda x: abs(x[1]), reverse=True)

        top_features = pairs[:5]

        for rank, (fname, fval) in enumerate(top_features, start=1):
            rows.append({
                "match_id": match_id,
                "feature_name": fname,
                "impact_value": float(fval),
                "rank": rank,
            })

    shap_df = pd.DataFrame(rows)

    with engine.begin() as conn:
        conn.execute(text("DELETE FROM explanations"))

        for _, row in shap_df.iterrows():
            conn.execute(
                text("""
                    INSERT INTO explanations (
                        match_id,
                        feature_name,
                        impact_value,
                        rank
                    )
                    VALUES (
                        :match_id,
                        :feature_name,
                        :impact_value,
                        :rank
                    )
                """),
                row.to_dict(),
            )

    print("SHAP explanations stored successfully!")


if __name__ == "__main__":
    main()
