# =========================
# PostgreSQL
# =========================
POSTGRES_DB=ipl_db
POSTGRES_USER=ipl_user
POSTGRES_PASSWORD=ipl_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# SQLAlchemy / Python DB connection
DATABASE_URL=postgresql+psycopg2://ipl_user:ipl_password@postgres:5432/ipl_db

# =========================
# FastAPI Backend
# =========================
API_HOST=0.0.0.0
API_PORT=8000

# =========================
# Frontend (Next.js)
# =========================
NEXT_PUBLIC_API_BASE=http://localhost:8000

# =========================
# MLflow
# =========================
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=ipl_prediction

# =========================
# ML Artifacts
# =========================
MODEL_PATH=/app/ml/artifacts/logreg_prematch.joblib
PREMATCH_FEATURES_PATH=/app/ml/artifacts/pre_match_features.csv
UPCOMING_FEATURES_PATH=/app/ml/artifacts/upcoming_match_features.csv

# =========================
# App Environment
# =========================
APP_ENV=local
LOG_LEVEL=INFO

# =========================
# Optional Scraping / External Sources
# =========================
IPL_FIXTURES_URL=https://www.iplt20.com/matches/fixtures
IPL_TEAMS_URL=https://www.iplt20.com/teams

# =========================
# Optional Future API Keys
# Leave blank for now
# =========================
SPORTS_API_KEY=
CRICAPI_KEY=
ODDS_API_KEY=
